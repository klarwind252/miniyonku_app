# ===================================================================
# ミニ四駆レース管理システム — クラウド版 環境変数サンプル
# さくらのVPS（Ubuntu 24.04）での常設運用を想定。
#
# 使い方:
#   1. このファイルを /etc/miniyonku/miniyonku.env としてコピー
#   2. 値を実際のものに変更（特に ADMIN_TOKEN / VIEW_TOKEN は必ず変更）
#   3. systemd サービス（deploy/miniyonku.service）が EnvironmentFile として読み込む
#
# オンプレ版ではこのファイルは不要（DEPLOY_MODE 未設定 → onprem 既定）。
# ===================================================================

# デプロイモード: onprem（既定）| cloud
DEPLOY_MODE=cloud

# 公開ベースURL（https。末尾スラッシュなし）
# 複数店舗では各店舗URLは PUBLIC_BASE_URL + "/{slug}" で構成される
# 例: https://example.vs.sakura.ne.jp/store2/admin/
PUBLIC_BASE_URL=https://example.vs.sakura.ne.jp

# --- 固定トークン認証 ---
# ★複数店舗化に伴う変更点★
#   ADMIN_TOKEN / VIEW_TOKEN は「店舗1（既定店舗）の初期トークン」として扱われ、
#   初回起動時にレジストリ（data/control.db）へ移行・保存される。
#   以降の各店舗トークンはレジストリで管理され、管理画面（店舗1の設定→複数店舗展開）
#   から店舗ごとに再生成できる。店舗2〜のトークンは追加時に自動生成される。
#   ※初回移行後は、この値を変更しても既存トークンは上書きされない
#     （店舗1のトークンを変えたい場合は管理画面の「トークン再生成」を使う）。
# 生成例: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=CHANGE_ME_admin_long_random_token
VIEW_TOKEN=CHANGE_ME_view_long_random_token

# --- 参加者向け静的HTML配信（クラウド=VPS nginx 直接配信）---
# ★複数店舗化に伴う変更点★
#   このディレクトリは「親ディレクトリ」として扱う。
#     店舗1（既定）: {PUBLIC_HTML_DIR}/index.html        → URL "/"
#     店舗2〜      : {PUBLIC_HTML_DIR}/{slug}/index.html → URL "/{slug}/"
#   レース用DBも店舗ごとに分離される:
#     店舗1: data/miniyonku.db（既存をそのまま使用）
#     店舗2〜: data/stores/{slug}/miniyonku.db
#     レジストリ: data/control.db（店舗マスタ。レーススキーマとは別ファイル）
#     削除店舗: data/_archive/{slug}_{日時}/（アーカイブ退避。物理削除しない）
PUBLIC_HTML_DIR=/var/www/miniyonku_public

# --- 待ち受けポート（nginx が前段でリバースプロキシ）---
PORT=8000
