# =============================================================================
# デモ（お試し）予約 追加設定
#   既存の /etc/miniyonku/miniyonku.env にこの内容を追記してください。
#   デモ予約はクラウド版（DEPLOY_MODE=cloud）でのみ有効です。
# =============================================================================

# ---- デモ予約の基本 ----
DEMO_ENABLED=true
DEMO_STORE_SLUGS=demo1,demo2,demo3,demo4     # デモ用店舗（1〜4）
DEMO_STORE_NAME_FMT=お試し{n}                # 自動作成される店舗名（{n}=1..4）

# ---- 予約枠（カレンダー） ----
DEMO_SLOT_MINUTES=60        # 1枠の長さ（分）
DEMO_DAY_START=10:00        # 受付開始（JST）
DEMO_DAY_END=20:00          # 受付終了（JST）… この時刻までに終わる枠まで
DEMO_DAYS_AHEAD=14          # 何日先まで予約可（当日含む）
DEMO_LEAD_MINUTES=10        # 現在時刻からこれだけ先の枠のみ予約可

# ---- 案内メールに載せるURL ----
DEMO_SEND_ADMIN_URL=true    # 管理URL（操作してお試し）
DEMO_SEND_VIEW_URL=true     # 観覧URL（結果確認）

# ---- 各セッション開始前に配るサンプルDB（任意）----
# 指定すると、予約確定のたびにデモ店舗DBをこのファイルの内容へ初期化します。
# 未指定なら前回セッションのデータが残ります（都度リセットしたい場合に設定）。
# DEMO_SEED_DB=/opt/miniyonku/seed/demo_seed.db

# ---- メール送信（Vultr サーバー単体で完結：ローカル postfix を使用）----
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_STARTTLS=false
SMTP_SSL=false
# SMTP_USER=                # localhost postfix なら不要
# SMTP_PASSWORD=

# 差出人（今回は Vultr の逆引きホスト名を postfix の mail name に設定済み）
# ※ 独自ドメインを使える場合は、この値と postfix の mail name を独自ドメインへ差し替え、
#    SPF レコード（例: v=spf1 a mx ~all）を追加すると到達率が上がります。
SMTP_FROM=noreply@<VPSの逆引きFQDN または 独自ドメイン>
SMTP_FROM_NAME=ミニ四駆お試し
# SMTP_FROM を使わずドメインだけ指定する場合の代替:
# SMTP_FROM_DOMAIN=<VPSの逆引きFQDN または 独自ドメイン>

DEMO_MAIL_SUBJECT=【ミニ四駆レース管理システム】お試しプレイ用URLのご案内

# 外部SMTPリレーを使う場合の例（ローカルpostfixを立てない場合）:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_STARTTLS=true
# SMTP_USER=your-user
# SMTP_PASSWORD=your-password
